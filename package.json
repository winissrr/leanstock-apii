{
  "name": "leanstock-api",
  "version": "1.0.0",
  "description": "Production-grade inventory management backend — LeanStock",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "helmet": "7.1.0",
    "ioredis": "5.4.1",
    "js-yaml": "4.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "node-cron": "3.0.3",
    "nodemailer": "6.9.14",
    "rate-limiter-flexible": "5.0.3",
    "swagger-ui-express": "5.0.1",
    "uuid": "9.0.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "prisma": "5.14.0",
    "supertest": "7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
