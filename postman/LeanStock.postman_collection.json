            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sku\": \"SKU-001\",\n  \"name\": \"Rice Bag\",\n  \"unitPrice\": 12.5,\n  \"reorderThreshold\": 4,\n  \"isDecayEnabled\": true,\n  \"decayDaysThreshold\": 7,\n  \"decayPercent\": 10\n}"
        }
      }
    },
    {
      "name": "List Products",
      "request": {
        "method": "GET",
        "header": [
          {
